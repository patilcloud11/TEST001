# ============================================================
# AI-Powered Family Finance Management System
# Backend Environment Variables
#
# LOCAL DEV:
#   Copy this to .env and fill in your values
#   cp .env.example .env
#
# AWS PRODUCTION (EC2):
#   DO NOT create .env manually on EC2.
#   The Terraform user-data script writes .env automatically at boot,
#   pulling secrets from AWS SSM Parameter Store.
#   Never commit .env to git — it is in .gitignore.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# ── AWS Configuration ─────────────────────────────────────────
# LOCAL DEV ONLY: set your AWS keys here for local testing
# AWS EC2: leave these blank — EC2 IAM role provides credentials automatically
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=             # local dev only — leave blank on EC2
AWS_SECRET_ACCESS_KEY=         # local dev only — leave blank on EC2

# ── DynamoDB Table Names ──────────────────────────────────────
# Local dev: use separate tables (run: npm run setup-db first)
DYNAMODB_USERS_TABLE=finance_users
DYNAMODB_FAMILIES_TABLE=finance_families
DYNAMODB_EXPENSES_TABLE=finance_expenses
DYNAMODB_BILLS_TABLE=finance_bills
DYNAMODB_INVESTMENTS_TABLE=finance_investments

# ── Groq AI API ───────────────────────────────────────────────
# Get free key at: console.groq.com
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_KEY
GROQ_MODEL=llama3-70b-8192

# ── Alpha Vantage (market data) ───────────────────────────────
# Get free key at: alphavantage.co
ALPHA_VANTAGE_API_KEY=REPLACE_WITH_YOUR_ALPHA_VANTAGE_KEY

# ── CORS / Frontend URL ───────────────────────────────────────
# Local dev: your Vite dev server port
# AWS prod:  set automatically by user-data to https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
